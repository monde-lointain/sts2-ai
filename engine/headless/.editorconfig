root = true

# C# style + analyzer config for Q1 (engine/headless).
# Companion files:
#   - stylecop.json — StyleCop rule config
#   - .csharpierrc.json — CSharpier formatter
#   - Directory.Build.props — analyzer PackageReferences

[*.cs]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# Banned-API: keep as error (RS0030 enforces engine boundary surface).
dotnet_diagnostic.RS0030.severity = error

# ----- Code-style preferences -----
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# ----- Using directives -----
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true

# ----- StyleCop suppressions -----
# XML comment analysis: fires when GenerateDocumentationFile is unset.
# We don't ship XML docs; disable analyzer entirely.
dotnet_diagnostic.SA0001.severity = none  # XmlCommentAnalysisDisabled
# Documentation rules — we don't enforce headers/XML-doc completeness.
dotnet_diagnostic.SA1600.severity = none  # ElementsMustBeDocumented
dotnet_diagnostic.SA1601.severity = none  # PartialElementsMustBeDocumented
dotnet_diagnostic.SA1602.severity = none  # EnumerationItemsMustBeDocumented
dotnet_diagnostic.SA1623.severity = none  # PropertySummaryDocumentationMustMatchAccessors
dotnet_diagnostic.SA1633.severity = none  # FileMustHaveHeader
dotnet_diagnostic.SA1636.severity = none  # FileHeaderCopyrightTextMustMatch
dotnet_diagnostic.SA1649.severity = none  # FileNameMustMatchTypeName
dotnet_diagnostic.SA1652.severity = none  # EnableXmlDocumentationOutput
# Naming / placement preferences that fight our convention.
dotnet_diagnostic.SA1101.severity = none  # PrefixLocalCallsWithThis
dotnet_diagnostic.SA1200.severity = none  # UsingDirectivesMustBePlacedCorrectly
dotnet_diagnostic.SA1309.severity = none  # FieldNamesMustNotBeginWithUnderscore (we allow _camelCase)
dotnet_diagnostic.SA1413.severity = none  # UseTrailingCommasInMultiLineInitializers
# CSharpier vs StyleCop layout conflicts — formatter wins.
dotnet_diagnostic.SA1009.severity = none  # ClosingParenthesisMustBeSpacedCorrectly
dotnet_diagnostic.SA1500.severity = none  # BracesForMultiLineStatementsMustNotShareLine (CSharpier do/while)
dotnet_diagnostic.SA1519.severity = none  # BracesForMultiLineStatementsMustNotShareLine (alt form)
# Naming-style preferences that conflict with codebase conventions.
dotnet_diagnostic.SA1300.severity = none  # ElementMustBeginWithUppercaseLetter (P/Invoke names match C lib)
dotnet_diagnostic.SA1307.severity = none  # AccessibleFieldsMustBeginWithUpperCaseLetter (we use _camelCase)
dotnet_diagnostic.SA1310.severity = none  # FieldNamesMustNotContainUnderscore (we allow _camelCase)
dotnet_diagnostic.SA1313.severity = none  # ParameterNamesMustBeginWithLowercaseLetter (record positional params)
# Modernization preferences we don't enforce uniformly.
dotnet_diagnostic.CA1512.severity = none  # use ArgumentOutOfRangeException.ThrowIfXxx
dotnet_diagnostic.CA1513.severity = none  # use ObjectDisposedException.ThrowIf
dotnet_diagnostic.CA2263.severity = none  # prefer generic overload
# Codebase-wide design preferences.
dotnet_diagnostic.CA1859.severity = none  # interface params kept for testability + immutability
dotnet_diagnostic.CA1711.severity = none  # *Stream / *Queue suffixes match domain language
dotnet_diagnostic.CA1068.severity = none  # CancellationToken position pragmatic, not last
dotnet_diagnostic.SA1111.severity = none  # ClosingParenthesisMustBeOnLineOfLastParameter
dotnet_diagnostic.SA1502.severity = none  # ElementMustNotBeOnSingleLine
dotnet_diagnostic.SA1503.severity = none  # BracesMustNotBeOmitted
dotnet_diagnostic.SA1512.severity = none  # SingleLineCommentsMustNotBeFollowedByBlankLine
dotnet_diagnostic.SA1513.severity = none  # ClosingBraceMustBeFollowedByBlankLine
dotnet_diagnostic.SA1515.severity = none  # SingleLineCommentMustBePrecededByBlankLine
dotnet_diagnostic.SA1516.severity = none  # ElementsMustBeSeparatedByBlankLine
# Codebase organization choices.
dotnet_diagnostic.SA1201.severity = none  # ElementsMustAppearInTheCorrectOrder
dotnet_diagnostic.SA1202.severity = none  # ElementsMustBeOrderedByAccess
dotnet_diagnostic.SA1204.severity = none  # StaticElementsMustAppearBeforeInstanceElements
dotnet_diagnostic.SA1402.severity = none  # FileMayOnlyContainASingleType
# Keep on: SA1407 (arithmetic precedence), SA1308/SA1311 (naming)

# ----- Roslyn naming rules -----
# PascalCase for public/internal members; _camelCase for private fields.
dotnet_naming_rule.types_pascal.severity = warning
dotnet_naming_rule.types_pascal.symbols = types_symbols
dotnet_naming_rule.types_pascal.style = pascal_style
dotnet_naming_symbols.types_symbols.applicable_kinds = class,struct,enum,interface,delegate
dotnet_naming_style.pascal_style.capitalization = pascal_case

dotnet_naming_rule.private_fields_camel.severity = suggestion
dotnet_naming_rule.private_fields_camel.symbols = private_field_symbols
dotnet_naming_rule.private_fields_camel.style = underscore_camel_style
dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_style.capitalization = camel_case
dotnet_naming_style.underscore_camel_style.required_prefix = _
